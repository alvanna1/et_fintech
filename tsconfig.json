{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        /* Linting */
        "strict": true,
        "noImplicitAny": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true,
        "baseUrl": "src", // 將 baseUrl 設置為你的源碼目錄
        "paths": {
            "@/*": ["*"] // 這樣你可以使用 '@/assets/...'
        }
    },
    "include": [
        "src", 
        "public/common/js/jquery-1.11.3.min.js",
        "public/common/js/bootstrap.js",
        "public/common/js/jquery.easing.1.3.js"    
    ],
    "exclude": [
        "**/*_backup_*.ts",
        "**/*_backup_*.tsx",
        "**/* copy.ts",
        "**/* copy.tsx",
        "src/routers/_backup_*.tsx"
    ],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}